# dependencies
node_modules/

# Next.js build output
.next/
out/

# TypeScript generated files (never commit — regenerated by `next typegen` / `tsc`)
next-env.d.ts
*.tsbuildinfo

# Cloudflare tunnel runtime state
.runtime/

# Local SQLite database (created at runtime — never commit)
data/*.db
data/*.db-wal
data/*.db-shm
data/*.db-journal

# Secrets and local environment overrides (never commit)
.env
.env.*
!.env.local.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS / editor artefacts
.DS_Store
.DS_Store?
._*
Thumbs.db

# Editor config directories
.vscode/
.idea/

# Test / coverage output
coverage/
playwright-report/
test-results/
test/alias-loader.mjs.map

# Temporary files
*.tmp
*.temp

# Local performance log captures (never commit — may contain raw lifecycle data)
.performance-logs/
*.lifecycle.jsonl
