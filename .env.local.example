# Copy this file to ".env.local" and fill in the values. Never commit .env.local.
# Restart `npm run dev` after any change here (Next.js reads env only at startup).

# ---- App -> Rovo : you SEND these (from the Incoming webhook trigger screen) ----
ROVO_WEBHOOK_URL=https://api.atlassian.com/automation/sc3/o/studio/t/workspace/i/<id>/webhooks/a/<id>
ROVO_WEBHOOK_SECRET=paste-the-Secret-shown-on-the-Incoming-webhook-trigger

# ---- Rovo -> App : the tunnel + callback ----
# QUICK tunnel (default, no account, random URL): leave BOTH blank. `npm run dev` detects the
#   *.trycloudflare.com URL automatically and saves it to .runtime/public-url.json. Open the app
#   at http://localhost:3000 - the callback URL is resolved from the saved file, no copy/paste needed.
# NAMED tunnel (custom, permanent URL - after the README "Custom, permanent URL" setup): set BOTH.
# TUNNEL_NAME=adalfi-ux-kb
# PUBLIC_BASE_URL=https://adalfi-ux-kb.YOURDOMAIN.com
#
# Invent a long random string. Put the SAME value in the Rovo "Send web request" header X-Callback-Token.
CALLBACK_SHARED_SECRET=change-me-to-a-long-random-string

# ---- Tuning (optional) ----
# How long to wait for the callback before a pending reply is marked failed (the watchdog).
PHASE_TIMEOUT_SECONDS=180
