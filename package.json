{
  "name": "adalfi-orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "AdalFi KB orchestration chat shell (V1, file v2 architecture): chat UI -> Rovo Studio webhook -> agent -> push-back callback.",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:next": "next dev",
    "dev:local": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "node --import ./test/setup.mjs --test test/*.test.mjs",
    "performance:analyze": "node scripts/analyze-performance.mjs",
    "performance:capture": "mkdir -p .performance-logs && npm run dev 2>&1 | tee .performance-logs/capture-$(date +%Y%m%d-%H%M%S).jsonl"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "next": "^16.2.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "engines": {
    "node": ">=24.15.0 <25"
  },
  "packageManager": "npm@12.0.1",
  "allowScripts": {
    "better-sqlite3@11.10.0": true
  }
}
